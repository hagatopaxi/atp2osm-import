#!/bin/bash
set -euo pipefail

# GIT_DIR is always a subdirectory of the project root:
# projects/atp2osm-import/repo.git  →  PROJECT_DIR = projects/atp2osm-import
PROJECT_DIR="$(cd "$(dirname "$GIT_DIR")"/.. && pwd)"
PROJECT_NAME=$(basename "$PROJECT_DIR")
if [ -z "$PROJECT_NAME" ] || [ "$PROJECT_NAME" = "." ]; then
  echo "ERROR: could not resolve project name from PROJECT_DIR='$PROJECT_DIR'" >&2
  exit 1
fi
CONTAINER_NAME="${PROJECT_NAME//./-}"
IMAGE_NAME="$CONTAINER_NAME"

# Read PORT from .env for display (falls back to 8000)
PORT=$(grep -E '^PORT=' "$PROJECT_DIR/.env" 2>/dev/null | cut -d'=' -f2 | tr -d '[:space:]' || true)
PORT="${PORT:-8000}"

QUADLET_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/containers/systemd"
SYSTEMD_USER_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/systemd/user"

echo ""
echo "==> Deploying $PROJECT_NAME"

# --- [1/3] Extract commit --------------------------------------------------
WORK_DIR=$(mktemp -d)
trap 'rm -rf "$WORK_DIR"' EXIT

COMMIT="${GIT_COMMIT:-HEAD}"
echo "--> [1/3] Extracting $COMMIT..."
git --git-dir="$GIT_DIR" archive "$COMMIT" | tar -x -C "$WORK_DIR"

# --- [2/3] Build image (tag :latest and :<git-short>) ----------------------
echo "--> [2/3] Building image..."
GIT_SHORT=$(git --git-dir="$GIT_DIR" rev-parse --short=6 "$COMMIT")
podman build \
  --build-arg "GIT_COMMIT=$GIT_SHORT" \
  --tag "${IMAGE_NAME}:latest" \
  --tag "${IMAGE_NAME}:${GIT_SHORT}" \
  "$WORK_DIR"
echo "    Tagged as ${IMAGE_NAME}:latest and ${IMAGE_NAME}:${GIT_SHORT}"

# --- [3/3] Write unit files + reload + restart -----------------------------
echo "--> [3/3] Writing unit files..."
mkdir -p "$QUADLET_DIR" "$SYSTEMD_USER_DIR" "$PROJECT_DIR/data" "$PROJECT_DIR/logs"

export PROJECT_NAME PROJECT_DIR IMAGE_NAME CONTAINER_NAME

# Container Quadlet
envsubst < "$WORK_DIR/deploy/atp2osm.container" > "$QUADLET_DIR/${CONTAINER_NAME}.container"

# Refresh timer units
envsubst < "$WORK_DIR/deploy/refresh.service" > "$SYSTEMD_USER_DIR/${CONTAINER_NAME}-refresh.service"
envsubst < "$WORK_DIR/deploy/refresh.timer"   > "$SYSTEMD_USER_DIR/${CONTAINER_NAME}-refresh.timer"

# Keep runner entry point up to date on each deploy
# (src/, osm2pgsql/, etc. live inside the container image)
git --git-dir="$GIT_DIR" archive "$COMMIT" -- run-pipeline.sh | tar -x -C "$PROJECT_DIR"
chmod +x "$PROJECT_DIR/run-pipeline.sh"

# Disable legacy units if present (path watcher + old timer named with dots)
systemctl --user disable --now "${CONTAINER_NAME}-watch.path"  2>/dev/null || true
systemctl --user disable --now "${PROJECT_NAME}-refresh.timer" 2>/dev/null || true

# Reload systemd, restart container, enable refresh timer
systemctl --user daemon-reload
systemctl --user restart "${CONTAINER_NAME}.service"
systemctl --user enable --now "${CONTAINER_NAME}-refresh.timer"

# Keep the 3 most recent git-tagged images, remove older ones
echo "    Pruning old images (keeping last 3)..."
podman images --format "{{.Repository}}:{{.Tag}}" \
  | grep "^${IMAGE_NAME}:" | grep -v ":latest" \
  | sort | head -n -3 \
  | xargs -r podman rmi 2>/dev/null || true

echo ""
echo "==> Done — $PROJECT_NAME deploying on port $PORT"
echo "    Image:        ${IMAGE_NAME}:latest (${GIT_SHORT})"
echo "    Container:    ${CONTAINER_NAME}.service (restarted)"
echo "    Refresh:      ${CONTAINER_NAME}-refresh.timer (enabled)"
echo "    Follow logs:  journalctl --user -u ${CONTAINER_NAME}.service -f"
